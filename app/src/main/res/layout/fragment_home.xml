<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/backgroundcolor"
    android:fillViewport="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".fragments.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/llHeaderHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/lightgreen"
            android:gravity="center_vertical"
            android:padding="@dimen/_8sdp"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfileImageofHome"
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:scaleType="centerInside"
                android:padding="@dimen/_8sdp"
                android:background="#F2F4F7"
                android:src="@drawable/user"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                android:elevation="@dimen/_4sdp" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_10sdp"
                android:text="Hello Name"
                android:textColor="@color/blackR"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnNotification"
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:background="#F2F4F7"
                android:padding="@dimen/_5sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:scaleType="centerInside"
                android:src="@drawable/bell"
                android:elevation="@dimen/_4sdp"
                android:stateListAnimator="@animator/button_click_animator"
                app:shapeAppearanceOverlay="@style/CircleImageView" />
        </LinearLayout>

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSearchHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_5sdp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_4sdp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#E4E7EC"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/llHeaderHome">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_12sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search Creator, Campaign, Tasks"
                    android:textColorHint="@color/grey"
                    android:textSize="@dimen/_11ssp"
                    android:fontFamily="@font/poppins"
                    android:layout_centerVertical="true" />

                <ImageButton
                    android:id="@+id/btnSearchHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="Search"
                    android:src="@drawable/search"
                    app:tint="@color/green" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stat Cards -->
        <HorizontalScrollView
            android:id="@+id/hsvStatsHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/cvSearchHome">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_5sdp"
                android:paddingBottom="@dimen/_5sdp">

                <!-- Active Tasks Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_125sdp"
                    android:layout_height="@dimen/_120sdp"
                    android:layout_margin="@dimen/_4sdp"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="@dimen/_5sdp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/button_click_animator">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_10sdp">

                        <ImageView
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:src="@drawable/ic_tasks"
                            android:layout_marginBottom="@dimen/_8sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tasks"
                            android:textSize="@dimen/_12ssp"
                            android:textColor="@color/grey"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvActiveTasksCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/_18ssp"
                            android:textColor="@color/blackR"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- All Collabs Card -->

                <!-- Growth Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_125sdp"
                    android:layout_height="@dimen/_120sdp"
                    android:layout_margin="@dimen/_4sdp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/button_click_animator"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="@dimen/_5sdp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/_10sdp">

                        <ImageView
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:layout_marginBottom="@dimen/_8sdp"
                            android:src="@drawable/ic_collab" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="Collabs"
                            android:textColor="@color/grey"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvActiveCollabsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/blackR"
                            android:textSize="@dimen/_18ssp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_125sdp"
                    android:layout_height="@dimen/_120sdp"
                    android:layout_margin="@dimen/_4sdp"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="@dimen/_5sdp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/button_click_animator">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_10sdp"
                        android:background="@drawable/button_gradient">

                        <ImageView
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:src="@drawable/growth"
                            app:tint="@color/white"
                            android:layout_marginBottom="@dimen/_8sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Growth"
                            android:textSize="@dimen/_12ssp"
                            android:textColor="@color/white"
                            android:alpha="0.8"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvCompletedCollabsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/_18ssp"
                            android:textColor="@color/white"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Todays Tasks Section -->
        <LinearLayout
            android:id="@+id/llTodaysTasksHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/hsvStatsHome">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Todays Tasks"
                    android:textColor="#101828"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAllCampaigns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="@color/green"
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodaysTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/_8sdp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_campaign_layout" />
        </LinearLayout>

        <!-- Collab Requests Section -->
        <LinearLayout
            android:id="@+id/llCollabRequestsHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/llTodaysTasksHome">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Collab Requests"
                    android:textColor="#101828"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNewCollabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 new"
                    android:paddingVertical="@dimen/_4sdp"
                    android:paddingHorizontal="@dimen/_12sdp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_10ssp"
                    android:textStyle="bold"
                    android:background="@drawable/buttonlayout"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCollabRequests"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_250sdp"
                android:layout_marginTop="@dimen/_4sdp"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/_5sdp"
                android:nestedScrollingEnabled="true"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_collab_request_layout" />

            <!-- Progress Loader -->
            <ProgressBar
                android:id="@+id/pbHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green"
                android:visibility="gone" />

            <!-- Empty State Placeholder -->
            <LinearLayout
                android:id="@+id/llEmptyCollabs"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_200sdp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/_80sdp"
                    android:layout_height="@dimen/_80sdp"
                    android:alpha="0.4"
                    android:src="@drawable/ic_collab"
                    app:tint="@color/grey" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:text="No new collaboration requests"
                    android:textColor="@color/grey"
                    android:textSize="@dimen/_11ssp"
                    android:fontFamily="@font/poppins"
                    android:alpha="0.6" />
            </LinearLayout>

        </LinearLayout>

        <!-- Next Meeting Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvNextMeetingHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_10sdp"
            app:cardCornerRadius="@dimen/_20sdp"
            app:cardElevation="@dimen/_5sdp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/llCollabRequestsHome">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_gradient"
                android:padding="@dimen/_15sdp">

                <TextView
                    android:id="@+id/tvNextMeetingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEXT MEETING"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:textSize="@dimen/_10ssp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvMeetingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="Sync with Brand"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvNextMeetingLabel" />

                <TextView
                    android:id="@+id/tvMeetingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:text="2:00 PM"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvMeetingTitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJoinMeeting"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_32sdp"
                    android:backgroundTint="@color/white"
                    android:text="JOIN"
                    android:textAllCaps="false"
                    android:textColor="@color/green"
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/_10sdp"
                    app:elevation="@dimen/_2sdp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="@dimen/_20sdp"
                    android:stateListAnimator="@animator/button_click_animator"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom Spacer -->
        <View
            android:id="@+id/vBottomSpacerHome"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_40sdp"
            app:layout_constraintTop_toBottomOf="@id/cvNextMeetingHome"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Search Results OVERLAY (Removed as functionality moved to Activity) -->

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
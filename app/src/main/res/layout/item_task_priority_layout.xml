<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_10sdp"
    android:layout_marginVertical="@dimen/_5sdp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/_12sdp"
    app:cardElevation="@dimen/_2sdp"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_12sdp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfileImage"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_image"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivProfileImage"
                android:layout_toStartOf="@+id/tvPriority"
                android:layout_marginStart="@dimen/_8sdp"
                android:layout_centerVertical="true"
                android:text="User Name"
                android:textColor="@color/blackR"
                android:textSize="@dimen/_11ssp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/whitecardbackground"
                android:backgroundTint="#FEE2E2"
                android:paddingHorizontal="@dimen/_8sdp"
                android:paddingVertical="@dimen/_2sdp"
                android:text="Priority"
                android:textColor="#991B1B"
                android:textSize="@dimen/_8ssp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Category & Status Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp">

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:background="@drawable/whitecardbackground"
                android:backgroundTint="@color/lightgreen"
                android:paddingHorizontal="@dimen/_6sdp"
                android:paddingVertical="@dimen/_2sdp"
                android:text="Category: Fashion"
                android:textColor="@color/green"
                android:textSize="@dimen/_8ssp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/whitecardbackground"
                android:backgroundTint="#DBEAFE"
                android:paddingHorizontal="@dimen/_6sdp"
                android:paddingVertical="@dimen/_2sdp"
                android:text="Status: Active"
                android:textColor="#1E40AF"
                android:textSize="@dimen/_8ssp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6sdp"
            android:text="Task Title"
            android:textColor="@color/blackR"
            android:textSize="@dimen/_12ssp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Task Description goes here..."
            android:textColor="@color/assetgrey"
            android:textSize="@dimen/_9ssp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Skills Section -->
        <TextView
            android:id="@+id/tvSkillsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6sdp"
            android:text="Skills Required:"
            android:textColor="@color/blackR"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_2sdp"
            app:chipSpacingHorizontal="@dimen/_4sdp"
            app:chipSpacingVertical="0dp">
        </com.google.android.material.chip.ChipGroup>

        <!-- Progress Indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/pbTaskProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:progress="0"
            app:indicatorColor="@color/green"
            app:trackColor="@color/lightgreen"
            app:trackCornerRadius="@dimen/_2sdp"
            app:trackThickness="@dimen/_3sdp" />

        <!-- Footer Row: Timeline, Budget and Action -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_centerVertical="true">

                <ImageView
                    android:layout_width="@dimen/_12sdp"
                    android:layout_height="@dimen/_12sdp"
                    android:src="@drawable/timer"
                    app:tint="@color/grey" />

                <TextView
                    android:id="@+id/tvTimeline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_4sdp"
                    android:text="Timeline"
                    android:textColor="@color/grey"
                    android:textSize="@dimen/_9ssp" />

                <TextView
                    android:id="@+id/tvBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:text="Budget"
                    android:textColor="@color/green"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendRequest"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_26sdp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/green"
                android:text="Request"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/_9ssp"
                app:cornerRadius="@dimen/_8sdp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="@dimen/_10sdp" />
        </RelativeLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

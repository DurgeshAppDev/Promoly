<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundcolor"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".fragments.TasksFragment">

    <!--  Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/lightgreen"
            android:gravity="center_vertical"
            android:padding="@dimen/_8sdp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_10sdp"
                android:text="Collaboration Tasks"
                android:textColor="@color/blackR"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />


        </LinearLayout>

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_marginVertical="@dimen/_10sdp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_4sdp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#E4E7EC"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="@dimen/_10sdp">

                <EditText
                    android:id="@+id/etSearchTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Search tasks..."
                    android:inputType="text"
                    android:padding="@dimen/_12sdp"
                    android:paddingEnd="@dimen/_40sdp"
                    android:textColor="@color/blackR"
                    android:textSize="@dimen/_11ssp" />

                <ImageButton
                    android:id="@+id/btnSearchTasks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignEnd="@id/etSearchTasks"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="Search"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/search"
                    android:stateListAnimator="@animator/button_click_animator" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Task Filters -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_10sdp"
            android:paddingHorizontal="@dimen/_15sdp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/_5sdp"
                android:padding="@dimen/_2sdp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAllTasks"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="@dimen/_80sdp"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/lightgreen"
                    android:text="All Tasks"
                    android:textAllCaps="false"
                    android:textColor="@color/green"
                    android:textSize="@dimen/_10ssp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/_12sdp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@animator/button_click_animator" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMyTasks"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="@dimen/_80sdp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:backgroundTint="#F2F4F7"
                    android:text="My Tasks"
                    android:textAllCaps="false"
                    android:textColor="@color/grey"
                    android:textSize="@dimen/_10ssp"
                    app:cornerRadius="@dimen/_12sdp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@animator/button_click_animator" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTaskPriorities"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/_5sdp"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/_8sdp"
        android:paddingBottom="@dimen/_20sdp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_task_priority_layout" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/llEmptyTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/_80sdp"
            android:layout_height="@dimen/_80sdp"
            android:alpha="0.3"
            android:src="@drawable/ic_tasks"
            app:tint="@color/grey" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:text="No tasks found"
            android:textColor="@color/grey"
            android:textSize="@dimen/_11ssp"
            android:fontFamily="@font/poppins"
            android:alpha="0.6" />
    </LinearLayout>

    <!-- Loading State -->
    <ProgressBar
        android:id="@+id/pbTasks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/green"
        android:visibility="gone" />

</LinearLayout>